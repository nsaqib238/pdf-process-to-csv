# Adobe PDF Services API Credentials
# Get credentials from: https://developer.adobe.com/document-services/apis/pdf-services/
# 
# IMPORTANT: The system works WITHOUT these credentials using fallback extraction (pdfplumber)
# However, Adobe API provides better accuracy for:
# - OCR on scanned documents
# - Complex table extraction  
# - Document structure detection
# - Fonts with special encodings

ADOBE_CLIENT_ID=your_client_id_here
ADOBE_CLIENT_SECRET=your_client_secret_here

# Optional. Default max upload is 85MB (stays under Adobe PDF Services 100MB API cap).
# Set explicitly as bytes, e.g. 89128960 for 85MB:
# MAX_FILE_SIZE=89128960

# AI Enhancement (OpenAI GPT-4 Vision) - OPTIONAL
# Improves table detection coverage and quality using AI vision analysis.
# Get API key from: https://platform.openai.com/api-keys
#
# Features (all default to false, enable individually):
# - AI Table Discovery: Find tables missed by geometric detection
# - AI Caption Detection: Handle non-standard caption formats
# - AI Structure Validation: Fix malformed extractions and reject prose
#
# Cost: ~$0.70 per 100-page PDF (based on GPT-4o pricing)
# See AI_ENHANCEMENT_PLAN.md for details.

# OPENAI_API_KEY=sk-proj-...
# ENABLE_AI_TABLE_DISCOVERY=false
# ENABLE_AI_CAPTION_DETECTION=false
# ENABLE_AI_STRUCTURE_VALIDATION=false
# OPENAI_MODEL=gpt-4o
# AI_MAX_CALLS_PER_JOB=100
# AI_ALERT_COST_THRESHOLD=5.0
