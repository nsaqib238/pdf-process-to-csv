# ============================================
# ADOBE PDF SERVICES API (Optional)
# ============================================
# Get credentials from: https://developer.adobe.com/document-services/
# 
# IMPORTANT: System works WITHOUT these credentials using pdfplumber fallback
# Adobe provides better accuracy for:
# - OCR on scanned documents
# - Complex table extraction  
# - Document structure detection
# - Fonts with special encodings

ADOBE_CLIENT_ID=your_client_id_here
ADOBE_CLIENT_SECRET=your_client_secret_here
ADOBE_ORG_ID=your_org_id_here

# ============================================
# FILE PROCESSING SETTINGS
# ============================================

# Directory for uploaded files (default: uploads)
# UPLOAD_DIR=uploads

# Directory for output files (default: outputs)
# OUTPUT_DIR=outputs

# Maximum file size in bytes (default: 85MB = 89128960 bytes)
# Stays under Adobe PDF Services 100MB API cap
# MAX_FILE_SIZE=89128960

# OCR locale for text extraction (default: en-US)
# OCR_LOCALE=en-US

# Adobe Extract API chunking (for large PDFs)
# Adobe applies low page limit to scanned PDFs (~100 pages)
# ADOBE_EXTRACT_CHUNK_PAGES=100
# ADOBE_EXTRACT_MIN_CHUNK_PAGES=10

# Adobe SDK timeout settings (milliseconds; upload + extract polling)
# Defaults: 120s connect, 15min read — raise further if uploads still time out
# ADOBE_CONNECT_TIMEOUT_MS=120000
# ADOBE_READ_TIMEOUT_MS=900000

# ============================================
# TABLE EXTRACTION - CORE SETTINGS
# ============================================

# Enable Camelot/Tabula fusion (requires Java + Ghostscript installed)
# Improves table extraction quality for standards-style PDFs
# Set to false only if Java/Ghostscript are not available
ENABLE_TABLE_CAMELOT_TABULA=true

# When True, drops many unnumbered low-score tables (reduces false positives)
# When False, keeps more tables (better recall for standards like AS3000)
# Default: false (recommended for standards documents)
OMIT_UNNUMBERED_TABLE_FRAGMENTS=false

# Quality score threshold for triggering Camelot/Tabula fusion (0.0 - 1.0)
# Lower = try fusion more often (slower but better quality)
# Higher = use pdfplumber more often (faster but may miss complex tables)
# Default: 0.82
TABLE_PIPELINE_FUSION_TRIGGER_SCORE=0.82

# Always run fusion for every table (slowest, maximum recall)
# Only enable if Java dependencies work and speed is not critical
# Default: false
# TABLE_PIPELINE_ALWAYS_TRY_FUSION=false

# Limit number of pages to process (for debugging/testing)
# Leave commented for full document processing
# TABLE_PIPELINE_MAX_PAGES=50

# ============================================
# TABLE EXTRACTION - PDFPLUMBER TOLERANCES
# ============================================

# Fine-tuning for pdfplumber's find_tables() method
# Looser tolerances help with ruled AS/NZS-style tables
# Higher values = more aggressive table detection

# Horizontal snapping tolerance (default: 7)
TABLE_SNAP_X_TOLERANCE=7

# Vertical snapping tolerance (default: 6)
TABLE_SNAP_Y_TOLERANCE=6

# Line intersection tolerance (default: 6)
TABLE_INTERSECTION_TOLERANCE=6

# Horizontal join tolerance (default: 7)
TABLE_JOIN_X_TOLERANCE=7

# If primary find_tables finds nothing, retry with looser tolerances
# Default: true
TABLE_PIPELINE_PDFPLUMBER_LOOSE_SECOND_PASS=true

# ============================================
# TABLE EXTRACTION - PAGE SWEEP
# ============================================

# When pdfplumber finds zero tables on a page, run Camelot+Tabula sweep
# Requires ENABLE_TABLE_CAMELOT_TABULA=true
# Default: true (recommended for comprehensive extraction)
TABLE_PIPELINE_PAGE_SWEEP_WHEN_EMPTY=true

# Maximum number of tables to keep per page from sweep
# Tabula can over-segment, this limits false positives
# Default: 8
TABLE_PIPELINE_PAGE_SWEEP_MAX_PER_PAGE=8

# ============================================
# TABLE EXTRACTION - CAPTION DETECTION
# ============================================

# Use PDF word geometry to find "TABLE X.X" captions and search below
# Default: true (recommended)
TABLE_PIPELINE_CAPTION_ANCHOR_PASS=true

# Maximum vertical distance (in points) below caption to search for table
# Default: 520.0 (allows ~7 inches below caption)
TABLE_PIPELINE_CAPTION_ANCHOR_MAX_DEPTH_PT=520.0

# Maximum gap (in points) between caption bottom and table top
# Allows a few text/footer lines between caption and table
# Default: 300.0
TABLE_PIPELINE_CAPTION_ANCHOR_MAX_GAP_PT=300.0

# Merge continuation tables across pages (same table number, no caption on page 2)
# Default: true
TABLE_PIPELINE_MERGE_ADJACENT_UNNUMBERED_CONTINUATION=true

# For each TABLE caption, run pdfplumber + Camelot + Tabula
# More thorough but slower
# Default: true
TABLE_PIPELINE_CAPTION_REGION_MULTI_ENGINE=true

# If no table found in default band below caption, expand to page bottom and retry
# Default: true
TABLE_PIPELINE_CAPTION_REGION_EXPAND_WHEN_EMPTY=true

# ============================================
# TABLE EXTRACTION - HEADER RECONSTRUCTION
# ============================================

# Post-process tables with structure-first header reconstruction
# Improves multi-row header detection
# See TABLE_HEADER_RECONSTRUCT.md for details
# Default: true (recommended)
ENABLE_HEADER_RECONSTRUCTION=true

# ============================================
# 🆕 AI ENHANCEMENT (Optional - Requires OpenAI API Key)
# ============================================
# Improves table detection coverage and quality using GPT-4o Vision
# 
# Expected improvement: 34% → 60%+ coverage (+17 tables for AS3000 2018.pdf)
# Cost: ~$0.007 per page (~$0.70 per 100 pages, ~$1.40 for AS3000 2018.pdf)
# Processing time: 2-3 sec/page → 4-6 sec/page (2x slower)
# 
# Get API key from: https://platform.openai.com/api-keys
# See AI_ENHANCEMENT_PLAN.md and HOW_TO_GET_MORE_AI_COVERAGE.md for details

# Required: Your OpenAI API key (starts with sk-proj-...)
# OPENAI_API_KEY=sk-proj-...

# ============================================
# AI ENHANCEMENT - FEATURE FLAGS
# ============================================
# All features default to false - enable individually based on needs
# Each feature adds specific capabilities and cost

# AI Table Discovery (Vision-based)
# Find tables missed by geometric detection using GPT-4o Vision
# Expected: +8-12 tables, ~$0.50 per 200-page PDF
# Default: false
ENABLE_AI_TABLE_DISCOVERY=false

# AI Caption Detection (Text analysis)
# Handle non-standard caption formats and implicit references
# Example: "the following table shows...", "see table below"
# Expected: +3-5 tables, ~$0.30 per 200-page PDF
# Default: false
ENABLE_AI_CAPTION_DETECTION=false

# AI Structure Validation (Vision + structure analysis)
# Validate/correct borderline extractions and reject prose
# Expected: +2-3 tables, improves precision, ~$0.60 per 200-page PDF
# Default: false
ENABLE_AI_STRUCTURE_VALIDATION=false

# ============================================
# AI ENHANCEMENT - DISCOVERY MODE
# ============================================
# Controls how aggressively AI searches for tables
# Trade-off between coverage, cost, and processing time

# Mode options:
# - "weak_signals": Only pages with problems (default, conservative)
#   - Orphaned captions, low-quality extractions, failed pages
#   - Cost: ~$0.02-0.10 per 200-page PDF
#   - Coverage: +2-5 tables typically
#   - Speed: +10% processing time
#
# - "comprehensive": Analyze ALL pages with vision AI
#   - Maximum coverage, finds tables geometric methods completely miss
#   - Cost: ~$0.007 per page (~$1.10 for 158-page PDF)
#   - Coverage: +15-20 tables expected (achieves 60%+ coverage goal)
#   - Speed: 2x slower (doubles processing time)
#
# - "balanced": Enhanced weak signals + gap analysis (recommended)
#   - Keyword matching, multiple caption detection, intelligent targeting
#   - Cost: ~$0.30-0.50 per 200-page PDF
#   - Coverage: +8-12 tables expected
#   - Speed: +30% processing time

# Default: weak_signals (conservative, low cost)
AI_DISCOVERY_MODE=weak_signals

# Maximum cost limit for comprehensive/balanced modes (USD)
# Processing stops if this limit is reached to prevent runaway costs
# Default: 2.00
AI_COMPREHENSIVE_MAX_COST=2.00

# ============================================
# AI ENHANCEMENT - OPENAI SETTINGS
# ============================================

# OpenAI model to use (gpt-4o recommended for vision tasks)
# Options: gpt-4o, gpt-4o-mini (cheaper but lower quality)
# Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# Maximum API retry attempts on failure
# Default: 3
# OPENAI_MAX_RETRIES=3

# API request timeout in seconds
# Default: 60
# OPENAI_TIMEOUT_SECONDS=60

# ============================================
# AI ENHANCEMENT - COST & QUALITY CONTROLS
# ============================================

# Maximum AI API calls per job (prevents runaway costs)
# Default: 100 (sufficient for ~200-page PDF)
# AI_MAX_CALLS_PER_JOB=100

# Minimum confidence threshold for AI-discovered tables (0.0 - 1.0)
# Only accept tables with "high" confidence (≥ this threshold)
# Default: 0.7
# AI_DISCOVERY_CONFIDENCE_THRESHOLD=0.7

# Quality threshold for triggering AI validation (0.0 - 1.0)
# Tables with quality score below this will be validated by AI
# Default: 0.6
# AI_VALIDATION_QUALITY_THRESHOLD=0.6

# Log detailed token usage and cost information
# Useful for monitoring and optimization
# Default: true
# AI_LOG_TOKEN_USAGE=true

# Alert threshold for total AI cost per job (USD)
# Processing will continue but log warning if exceeded
# Default: 5.0
# AI_ALERT_COST_THRESHOLD=5.0

# ============================================
# API SERVER SETTINGS
# ============================================

# Host to bind the API server (default: 0.0.0.0 - all interfaces)
API_HOST=0.0.0.0

# Port for the API server (default: 8000)
API_PORT=8000
