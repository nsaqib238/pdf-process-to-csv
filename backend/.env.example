# ============================================
# ADOBE PDF SERVICES API (Optional)
# ============================================
# Get credentials from: https://developer.adobe.com/document-services/
# System works WITHOUT these - uses pdfplumber fallback

# ADOBE_CLIENT_ID=your_client_id_here
# ADOBE_CLIENT_SECRET=your_client_secret_here

# ============================================
# TABLE EXTRACTION - CORE SETTINGS
# ============================================

# Enable Camelot/Tabula fusion (requires Java + Ghostscript)
ENABLE_TABLE_CAMELOT_TABULA=true

# Keep unnumbered tables (better recall for standards documents)
OMIT_UNNUMBERED_TABLE_FRAGMENTS=false

# Quality threshold for fusion (lower = more fusion attempts)
TABLE_PIPELINE_FUSION_TRIGGER_SCORE=0.82

# Run Camelot+Tabula sweep on empty pages
TABLE_PIPELINE_PAGE_SWEEP_WHEN_EMPTY=true

# Caption-based table detection
TABLE_PIPELINE_CAPTION_ANCHOR_PASS=true

# Multi-engine caption region extraction
TABLE_PIPELINE_CAPTION_REGION_MULTI_ENGINE=true

# Header reconstruction
ENABLE_HEADER_RECONSTRUCTION=true

# ============================================
# 🆕 AI ENHANCEMENT (Optional - Requires OpenAI API Key)
# ============================================
# Improves table detection coverage and quality using GPT-4o Vision
# 
# Expected improvement: 34% → 60%+ coverage (+17 tables for AS3000 2018.pdf)
# Get API key from: https://platform.openai.com/api-keys
# See AI_ENHANCEMENT_PLAN.md and HOW_TO_GET_MORE_AI_COVERAGE.md for details

# Required: Your OpenAI API key (starts with sk-proj-...)
# OPENAI_API_KEY=sk-proj-...

# ============================================
# AI ENHANCEMENT - FEATURE FLAGS
# ============================================
# All features default to false - enable individually based on needs
# Each feature adds specific capabilities and cost

# 1. AI Table Discovery (Vision-based) - RECOMMENDED
# Find tables missed by geometric detection using GPT-4o Vision
# Expected: +8-12 tables (weak_signals), +15-20 tables (comprehensive)
# Cost: ~$0.10 (weak_signals), ~$1.10 (comprehensive) for 158-page PDF
# Default: false
ENABLE_AI_TABLE_DISCOVERY=false

# 2. AI Caption Detection (Text analysis)
# Handle non-standard caption formats and implicit references
# Example: "the following table shows...", "see table below"
# Expected: +3-5 tables, ~$0.30 per 200-page PDF
# Default: false
ENABLE_AI_CAPTION_DETECTION=false

# 3. AI Structure Validation (Vision + structure analysis)
# Validate/correct borderline extractions and reject prose
# Expected: +2-3 tables, improves precision, ~$0.60 per 200-page PDF
# Default: false
ENABLE_AI_STRUCTURE_VALIDATION=false

# ============================================
# AI ENHANCEMENT - DISCOVERY MODE
# ============================================
# Controls how aggressively AI searches for tables
# Only applies when ENABLE_AI_TABLE_DISCOVERY=true
# Trade-off between coverage, cost, and processing time

# Mode options:
# - "weak_signals": Only problematic pages (default, conservative)
#   - Orphaned captions, low-quality extractions, failed pages
#   - Cost: ~$0.02-0.10 per 200-page PDF
#   - Coverage: +2-5 tables typically
#   - Speed: +10% processing time
#
# - "comprehensive": Analyze ALL pages with vision AI ✅ MAXIMUM COVERAGE
#   - Maximum coverage, finds tables geometric methods completely miss
#   - Cost: ~$0.007 per page (~$1.10 for 158-page PDF)
#   - Coverage: +15-20 tables expected (achieves 60%+ coverage goal)
#   - Speed: 2x slower (doubles processing time)
#
# - "balanced": Enhanced weak signals + gap analysis (recommended)
#   - Keyword matching, multiple caption detection, intelligent targeting
#   - Cost: ~$0.30-0.50 per 200-page PDF
#   - Coverage: +8-12 tables expected
#   - Speed: +30% processing time

# Default: weak_signals (conservative, low cost)
AI_DISCOVERY_MODE=weak_signals

# Maximum cost limit for comprehensive/balanced modes (USD)
# Processing stops if this limit is reached to prevent runaway costs
# Default: 2.00
AI_COMPREHENSIVE_MAX_COST=2.00

# ============================================
# AI ENHANCEMENT - OPENAI SETTINGS
# ============================================

# OpenAI model to use (gpt-4o recommended for vision tasks)
# Options: gpt-4o, gpt-4o-mini (cheaper but lower quality)
# Default: gpt-4o
# OPENAI_MODEL=gpt-4o

# Maximum API retry attempts on failure
# Default: 3
# OPENAI_MAX_RETRIES=3

# API request timeout in seconds
# Default: 60
# OPENAI_TIMEOUT_SECONDS=60

# ============================================
# AI ENHANCEMENT - COST & QUALITY CONTROLS
# ============================================

# Maximum AI API calls per job (prevents runaway costs)
# Default: 100 (sufficient for ~200-page PDF)
# AI_MAX_CALLS_PER_JOB=100

# Minimum confidence threshold for AI-discovered tables (0.0 - 1.0)
# Only accept tables with "high" confidence (≥ this threshold)
# Default: 0.7
# AI_DISCOVERY_CONFIDENCE_THRESHOLD=0.7

# Quality threshold for triggering AI validation (0.0 - 1.0)
# Tables with quality score below this will be validated by AI
# Default: 0.6
# AI_VALIDATION_QUALITY_THRESHOLD=0.6

# Log detailed token usage and cost information
# Useful for monitoring and optimization
# Default: true
# AI_LOG_TOKEN_USAGE=true

# Alert threshold for total AI cost per job (USD)
# Processing will continue but log warning if exceeded
# Default: 5.0
# AI_ALERT_COST_THRESHOLD=5.0

# ============================================
# 📚 ADVANCED SETTINGS (Optional)
# ============================================
# Most users don't need to change these

# File paths
# UPLOAD_DIR=uploads
# OUTPUT_DIR=outputs

# File size limit (85MB, stays under Adobe's 100MB cap)
# MAX_FILE_SIZE=89128960

# OCR locale
# OCR_LOCALE=en-US

# Adobe API settings (for large PDFs)
# ADOBE_EXTRACT_CHUNK_PAGES=100
# ADOBE_EXTRACT_MIN_CHUNK_PAGES=10
# ADOBE_CONNECT_TIMEOUT_MS=15000
# ADOBE_READ_TIMEOUT_MS=120000

# Table extraction fine-tuning
# TABLE_SNAP_X_TOLERANCE=7
# TABLE_SNAP_Y_TOLERANCE=6
# TABLE_INTERSECTION_TOLERANCE=6
# TABLE_JOIN_X_TOLERANCE=7
# TABLE_PIPELINE_PDFPLUMBER_LOOSE_SECOND_PASS=true
# TABLE_PIPELINE_PAGE_SWEEP_MAX_PER_PAGE=8
# TABLE_PIPELINE_CAPTION_ANCHOR_MAX_DEPTH_PT=520.0
# TABLE_PIPELINE_CAPTION_ANCHOR_MAX_GAP_PT=300.0
# TABLE_PIPELINE_MERGE_ADJACENT_UNNUMBERED_CONTINUATION=true
# TABLE_PIPELINE_CAPTION_REGION_EXPAND_WHEN_EMPTY=true

# Debugging
# TABLE_PIPELINE_MAX_PAGES=50

# API server settings
# API_HOST=0.0.0.0
# API_PORT=8000
